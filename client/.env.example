# Leave VITE_API_URL unset in development to use Vite proxy (recommended).
# Requests will go to the same origin and be proxied to the API (see vite.config.ts).
#
# Only set this if you want the app to call the API directly (e.g. different host):
VITE_API_URL=https://localhost:7008

# GNews API key for the tabbed News card (https://gnews.io — free tier: 100 req/day).
# Without this key, the News card falls back to built-in dummy data.
VITE_GNEWS_API_KEY=41938e7c23ce7afa3c30fd310adfd2e8
